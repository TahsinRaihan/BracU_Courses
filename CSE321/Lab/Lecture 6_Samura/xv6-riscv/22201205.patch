+
+uint64
+sys_settickets(void)
+{
+  int n;
+  argint(0, &n);
+
+  if(n <= 0)
+    return -1;
+
+  struct proc *p = myproc();
+  acquire(&p->lock);
+  p->tickets = n;
+  release(&p->lock);
+  return 0;
+}
diff --git a/user/test_scheduler.c b/user/test_scheduler.c
new file mode 100644
index 0000000..95b08a0
--- /dev/null
+++ b/user/test_scheduler.c
@@ -0,0 +1,24 @@
+#include "kernel/types.h"
+#include "user/user.h"
+
+int
+main(int argc, char *argv[])
+{
+  if (argc != 2){
+    printf("Usage: test_scheduler <tickets>\n");
+    exit(1);
+  }
+
+  int tickets = atoi(argv[1]);
+  // Set the tickets for this process
+  if (settickets(tickets) < 0){
+    printf("settickets failed\n");
+    exit(1);
+  }
+
+  // Spin in an infinite loop to use CPU time
+  while(1){
+  }
+
+  exit(0);
+}
